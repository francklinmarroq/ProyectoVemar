<Window
    x:Class="ListadoColaboradoresWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="900"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <ListView ItemsSource="{Binding Colaboradores}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="50" DisplayMemberBinding="{Binding Id}" Header="Id" />
                    <GridViewColumn Width="80" DisplayMemberBinding="{Binding Dni}" Header="DNI" />
                    <GridViewColumn Width="200" DisplayMemberBinding="{Binding Nombre}" Header="Nombre" />
                    <GridViewColumn Width="110" DisplayMemberBinding="{Binding Telefono}" Header="Teléfono" />
                    <GridViewColumn Width="110" DisplayMemberBinding="{Binding FechaNacimiento, StringFormat='{}{0:dd/MM/yyyy}'}" Header="Fecha Nac." />
                    <GridViewColumn Width="200" DisplayMemberBinding="{Binding Domicilio}" Header="Domicilio" />
                    <GridViewColumn Width="200" DisplayMemberBinding="{Binding Email}" Header="Email" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
