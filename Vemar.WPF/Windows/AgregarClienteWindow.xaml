<Window x:Class="AgregarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:Vemar.WPF"
        Title="{Binding TituloFormulario}" WindowStyle="ToolWindow" ResizeMode="NoResize"
        SizeToContent="Height" Width="700" WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Margin="24" Background="White" CornerRadius="12" Padding="24,20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#000"/>
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="4" CornerRadius="2" Background="#3B82F6" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TituloFormulario}" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Fila 1: Nombre · Identidad · RTN · Teléfono · Email Corporativo -->
            <UniformGrid Columns="5" Margin="0,0,0,12">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Nombre Propietario" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Identidad Propietario" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding DniPropietario, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"
                             b:DniTextBoxBehavior.IsEnabled="True"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="RTN" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Rtn, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"
                             b:RtnTextBoxBehavior.IsEnabled="True"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Teléfono" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Telefono, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"
                             b:PhoneTextBoxBehavior.IsEnabled="True"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Email Corporativo" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EmailCorporativo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                </StackPanel>
            </UniformGrid>
            <!-- Fila 2: Representante · DNI Rep · RTN Rep · Tel. Representante -->
            <UniformGrid Columns="4" Margin="0,0,0,12">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Representante" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Representante, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="DNI Representante" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding DniRepresentante, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"
                             b:DniTextBoxBehavior.IsEnabled="True"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="RTN Representante" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding RtnRepresentante, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"
                             b:RtnTextBoxBehavior.IsEnabled="True"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Tel. Representante" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding TelefonoRepresentante, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"
                             b:PhoneTextBoxBehavior.IsEnabled="True"/>
                </StackPanel>
            </UniformGrid>
            <!-- Fila 3: Email Representante · Dirección -->
            <UniformGrid Columns="4" Margin="0,0,0,0">
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Email Representante" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EmailRepresentante, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0" Grid.Column="1">
                    <TextBlock Text="Dirección" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Direccion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldBox}"/>
                </StackPanel>
            </UniformGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Name="BtnCancelar" Content="Cancelar" Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"/>
                <Button Content="Guardar" Command="{Binding GuardarCommand}" Style="{StaticResource BtnPrimary}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>



