<Window x:Class="LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Constructora Vemar — Iniciar Sesión"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputPwd" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" MouseDown="Window_MouseDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Cabecera azul oscuro ── -->
            <Border Grid.Row="0" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1E3A8A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <!-- Círculo decorativo -->
                <Grid>
                    <Ellipse Width="320" Height="320" Opacity="0.12"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-80,-120">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Ícono -->
                        <Border Width="64" Height="64" CornerRadius="32"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0"/>
                                    <GradientStop Color="#1E40AF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <iconPacks:PackIconPhosphorIcons Kind="Buildings"
                                Width="30" Height="30" Foreground="White"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="CONSTRUCTORA VEMAR" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#93C5FD" HorizontalAlignment="Center"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="Iniciar Sesión" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Botón cerrar -->
                    <Button Click="BtnCerrar_Click" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,10,12,0"
                            Width="28" Height="28" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                    <iconPacks:PackIconPhosphorIcons Kind="X"
                                        Width="14" Height="14" Foreground="#64748B"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#1E3A8A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Formulario ── -->
            <StackPanel Grid.Row="1" Margin="36,28,36,28" VerticalAlignment="Top">

                <!-- Usuario -->
                <TextBlock Text="USUARIO" FontSize="10" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <TextBox x:Name="TxtUsername"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}"/>
                    <iconPacks:PackIconPhosphorIcons Kind="User" Width="16" Height="16"
                        Foreground="#94A3B8" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,12,0"
                        IsHitTestVisible="False"/>
                </Grid>

                <!-- Contraseña -->
                <TextBlock Text="CONTRASEÑA" FontSize="10" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,20">
                    <PasswordBox x:Name="PwdBox"
                                 Style="{StaticResource InputPwd}"
                                 PasswordChanged="PwdBox_PasswordChanged"/>
                    <iconPacks:PackIconPhosphorIcons Kind="Lock" Width="16" Height="16"
                        Foreground="#94A3B8" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,12,0"
                        IsHitTestVisible="False"/>
                </Grid>

                <!-- Mensaje de error -->
                <Border Background="#FFF1F2" BorderBrush="#FECDD3" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconPhosphorIcons Kind="XCircle" Width="16" Height="16"
                            Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                                   Foreground="#DC2626" Margin="8,0,0,0"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Botón Login -->
                <Button Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        Cursor="Hand" Height="44">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2563EB" Offset="0"/>
                                        <GradientStop Color="#1E40AF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <!-- Estado normal -->
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{Binding IsNotBusy, Converter={StaticResource BoolToVis}}">
                                        <iconPacks:PackIconPhosphorIcons Kind="SignIn"
                                            Width="16" Height="16" Foreground="White"
                                            VerticalAlignment="Center"/>
                                        <TextBlock Text="Ingresar al sistema" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="White"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- Estado ocupado -->
                                    <TextBlock Text="Verificando..." FontSize="13"
                                               FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
