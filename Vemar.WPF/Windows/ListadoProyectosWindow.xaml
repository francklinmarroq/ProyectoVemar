<Window
    x:Class="ListadoProyectosWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="900"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <ListView ItemsSource="{Binding Proyectos}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="50" DisplayMemberBinding="{Binding Id}" Header="Id" />
                    <GridViewColumn Width="200" DisplayMemberBinding="{Binding Nombre}" Header="Nombre" />
                    <GridViewColumn Width="200" DisplayMemberBinding="{Binding Ubicacion}" Header="Ubicación" />
                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding Matricula}" Header="Matrícula" />
                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding ClaveSure}" Header="Clave Sure" />
                    <GridViewColumn Width="80" DisplayMemberBinding="{Binding Area}" Header="Área (m²)" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
