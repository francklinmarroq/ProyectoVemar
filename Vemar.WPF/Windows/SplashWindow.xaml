<Window x:Class="SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Constructora Vemar"
        Width="860" Height="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Placeholder helper para TextBox via Tag -->
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}"
                                           Foreground="#94A3B8" FontSize="13"
                                           Margin="11,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Botón primario -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#1E40AF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón secundario -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#F0FDF4"/>
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="#BBF7D0" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#DCFCE7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#F0FDF4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón escanear (azul claro) -->
        <Style x:Key="BtnScan" TargetType="Button">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="#BFDBFE" BorderThickness="1" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#F8FAFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" MouseDown="Window_MouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- PANEL IZQUIERDO — Identidad de marca                       -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="#0F172A" ClipToBounds="True">

                <!-- Fondo decorativo: círculo grande -->
                <Grid>
                    <Ellipse Width="420" Height="420" Margin="-180,-80,0,0"
                             HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1E3A8A" Offset="0"/>
                                <GradientStop Color="#0F172A" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="300" Height="300" Margin="0,0,-120,-80"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0.4">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Contenido centrado verticalmente -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28,0">

                        <!-- Ícono / Logo circular -->
                        <Border Width="80" Height="80" CornerRadius="40"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0"/>
                                    <GradientStop Color="#1E40AF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <iconPacks:PackIconPhosphorIcons Kind="Buildings"
                                Width="40" Height="40" Foreground="White"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Nombre empresa -->
                        <TextBlock Text="CONSTRUCTORA" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#93C5FD"                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="VEMAR" FontSize="46" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="S. de R.L. de C.V." FontSize="11"
                                   Foreground="#64748B" HorizontalAlignment="Center"
                                   Margin="0,0,0,24"/>

                        <!-- Línea divisora -->
                        <Rectangle Height="1" Fill="#1E3A8A" Margin="0,0,0,20" Opacity="0.6"/>

                        <!-- Tagline -->
                        <TextBlock Text="Sistema de Gestión" FontSize="13"
                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Empresarial" FontSize="13"
                                   Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                        <!-- Íconos de características -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <iconPacks:PackIconPhosphorIcons Kind="Buildings" Width="14" Height="14"
                                Foreground="#475569" VerticalAlignment="Center"/>
                            <TextBlock Text="Proyectos" FontSize="10" Foreground="#475569"
                                       Margin="5,0,16,0" VerticalAlignment="Center"/>
                            <iconPacks:PackIconPhosphorIcons Kind="FileText" Width="14" Height="14"
                                Foreground="#475569" VerticalAlignment="Center"/>
                            <TextBlock Text="Trámites" FontSize="10" Foreground="#475569"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconPhosphorIcons Kind="Users" Width="14" Height="14"
                                Foreground="#475569" VerticalAlignment="Center"/>
                            <TextBlock Text="Personal" FontSize="10" Foreground="#475569"
                                       Margin="5,0,16,0" VerticalAlignment="Center"/>
                            <iconPacks:PackIconPhosphorIcons Kind="CurrencyCircleDollar" Width="14" Height="14"
                                Foreground="#475569" VerticalAlignment="Center"/>
                            <TextBlock Text="Finanzas" FontSize="10" Foreground="#475569"
                                       Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Versión pie -->
                    <TextBlock Text="v1.0  ·  2025" FontSize="10" Foreground="#334155"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- PANEL DERECHO — Configuración de conexión                  -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1" Background="#F8FAFC">

                <Grid>
                    <!-- Botón cerrar (X) -->
                    <Button Click="BtnCerrar_Click" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,12,14,0" Cursor="Hand"
                            Width="28" Height="28">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                                    <iconPacks:PackIconPhosphorIcons Kind="X" Width="14" Height="14"
                                        Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#FEE2E2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
                        <StackPanel Margin="36,28,36,28">

                            <!-- Título sección -->
                            <TextBlock Text="Conexión a Base de Datos"
                                       FontSize="20" FontWeight="Bold" Foreground="#0F172A"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="Seleccione o escanee instancias de SQL Server en la red."
                                       FontSize="12" Foreground="#64748B" Margin="0,0,0,22"
                                       TextWrapping="Wrap"/>

                            <!-- ── Servidor ── -->
                            <TextBlock Text="SERVIDOR SQL SERVER" Style="{StaticResource LabelText}"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"
                                         Tag="Ej: SERVIDOR\SQLEXPRESS"/>
                                <Button Grid.Column="2" Command="{Binding ScanCommand}"
                                        IsEnabled="{Binding IsNotBusy}"
                                        Style="{StaticResource BtnScan}" Width="130">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconPhosphorIcons Kind="MagnifyingGlass"
                                            Width="13" Height="13" Foreground="#1D4ED8"
                                            VerticalAlignment="Center"/>
                                        <TextBlock Text="Escanear red" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1D4ED8"
                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- Lista de servidores encontrados -->
                            <Border Visibility="{Binding ShowServerList, Converter={StaticResource BoolToVis}}"
                                    BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6"
                                    Background="White" Margin="0,0,0,8" MaxHeight="130">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FoundServers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Cursor="Hand" Padding="10,7" Background="Transparent"
                                                        x:Name="itemBg">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                            Command="{Binding DataContext.SelectServerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="Database"
                                                            Width="13" Height="13" Foreground="#3B82F6"
                                                            VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding}" FontSize="12"
                                                                   Foreground="#1E40AF" Margin="7,0,0,0"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#EFF6FF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- ── Base de datos ── -->
                            <TextBlock Text="BASE DE DATOS" Style="{StaticResource LabelText}" Margin="0,4,0,4"/>
                            <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FieldBox}"
                                     Tag="Nombre de la base de datos"
                                     Margin="0,0,0,14"/>

                            <!-- ── Autenticación ── -->
                            <TextBlock Text="AUTENTICACIÓN" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Windows (recomendado)"
                                             IsChecked="{Binding UseWindowsAuth, Mode=OneWay}"
                                             Checked="RadioWindows_Checked"
                                             FontSize="12" Foreground="#374151"
                                             GroupName="AuthGroup" Margin="0,0,20,0"/>
                                <RadioButton Content="SQL Server"
                                             IsChecked="{Binding ShowSqlAuth, Mode=OneWay}"
                                             Checked="RadioSql_Checked"
                                             FontSize="12" Foreground="#374151"
                                             GroupName="AuthGroup"/>
                            </StackPanel>

                            <!-- Credenciales SQL (oculto si Windows auth) -->
                            <StackPanel Visibility="{Binding ShowSqlAuth, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,0">
                                <TextBlock Text="USUARIO" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldBox}"
                                         Tag="Usuario SQL"
                                         Margin="0,0,0,10"/>
                                <TextBlock Text="CONTRASEÑA" Style="{StaticResource LabelText}"/>
                                <PasswordBox x:Name="PwdBox" Height="38" Padding="10,0"
                                             BorderBrush="#E2E8F0" BorderThickness="1"
                                             FontSize="13" Margin="0,0,0,10"
                                             PasswordChanged="PwdBox_PasswordChanged"/>
                            </StackPanel>

                            <!-- ── Indicador de estado ── -->
                            <Border x:Name="StatusBorder" CornerRadius="8" Padding="12,10"
                                    Margin="0,8,0,14">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F0F9FF"/>
                                        <Setter Property="BorderBrush" Value="#BAE6FD"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusType}" Value="Success">
                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                                <Setter Property="Background" Value="#FFF1F2"/>
                                                <Setter Property="BorderBrush" Value="#FECDD3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                                <Setter Property="Background" Value="#FFFBEB"/>
                                                <Setter Property="BorderBrush" Value="#FDE68A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Ícono estado o spinner -->
                                    <Grid Grid.Column="0" Width="22" Height="22" Margin="0,0,10,0">
                                        <!-- Spinner cuando ocupa -->
                                        <Border x:Name="Spinner" Width="18" Height="18"
                                                CornerRadius="9" BorderThickness="2.5"
                                                BorderBrush="#3B82F6"
                                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                                            <Border.RenderTransform>
                                                <RotateTransform x:Name="SpinnerRotation" CenterX="9" CenterY="9"/>
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                                Storyboard.TargetProperty="Angle"
                                                                From="0" To="360" Duration="0:0:0.8"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>

                                        <!-- Ícono estático -->
                                        <iconPacks:PackIconPhosphorIcons x:Name="StatusIcon"
                                            Width="18" Height="18" VerticalAlignment="Center"
                                            Visibility="{Binding IsNotBusy, Converter={StaticResource BoolToVis}}">
                                            <iconPacks:PackIconPhosphorIcons.Style>
                                                <Style TargetType="iconPacks:PackIconPhosphorIcons">
                                                    <Setter Property="Kind" Value="Info"/>
                                                    <Setter Property="Foreground" Value="#0284C7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StatusType}" Value="Success">
                                                            <Setter Property="Kind" Value="CheckCircle"/>
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                                            <Setter Property="Kind" Value="XCircle"/>
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                                            <Setter Property="Kind" Value="Warning"/>
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </iconPacks:PackIconPhosphorIcons.Style>
                                        </iconPacks:PackIconPhosphorIcons>
                                    </Grid>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusMessage}"
                                               FontSize="12" TextWrapping="Wrap"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#0369A1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusType}" Value="Success">
                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- ── Botones de acción ── -->
                            <Button Command="{Binding ConnectCommand}"
                                    IsEnabled="{Binding IsNotBusy}"
                                    Style="{StaticResource BtnPrimary}"
                                    Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconPhosphorIcons Kind="PlugsConnected"
                                        Width="16" Height="16" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="Conectar al sistema" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Botón crear BD (aparece cuando se necesita) -->
                            <Button Command="{Binding CreateDatabaseCommand}"
                                    IsEnabled="{Binding IsNotBusy}"
                                    Style="{StaticResource BtnSecondary}"
                                    Visibility="{Binding ShowCreateDb, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconPhosphorIcons Kind="Database"
                                        Width="16" Height="16" Foreground="#15803D" VerticalAlignment="Center"/>
                                    <TextBlock Text="Crear base de datos nueva" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
