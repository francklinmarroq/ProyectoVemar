<Window
    x:Class="ListadoContratistasWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="500"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <ListView ItemsSource="{Binding Contratistas}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="50" DisplayMemberBinding="{Binding Id}" Header="Id" />
                    <GridViewColumn Width="280" DisplayMemberBinding="{Binding Nombre}" Header="Nombre" />
                    <GridViewColumn Width="130" DisplayMemberBinding="{Binding Telefono}" Header="Teléfono" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
