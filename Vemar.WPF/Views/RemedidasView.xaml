<UserControl x:Class="RemedidasView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Background="#F1F5F9">
    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock"><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#3B82F6"/><Setter Property="Margin" Value="0,0,0,4"/></Style>
        <Style x:Key="Fld" TargetType="TextBox"><Setter Property="Height" Value="36"/><Setter Property="Padding" Value="10,0"/><Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="BorderThickness" Value="1"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
        <!-- DataGrid Styles -->
        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="6" Cursor="SizeWE"><Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template></Thumb>
                            <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="6" Cursor="SizeWE"><Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"><Rectangle Width="1" HorizontalAlignment="Right" Fill="#40FFFFFF"/></Border></ControlTemplate></Thumb.Template></Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#F0F4F8" BorderThickness="0,0,0,1">
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </SelectiveScrollingGrid.ColumnDefinitions>
                                <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" Grid.Column="1"/>
                            </SelectiveScrollingGrid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F9FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="10" Background="#EFF6FF" VerticalAlignment="Center">
                    <iconPacks:PackIconPhosphorIcons Kind="Ruler" Width="20" Height="20" Foreground="#3B82F6"/>
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Remedidas" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding ItemsView.Count, StringFormat='Total: {0} registros'}" FontSize="12" Foreground="#3B82F6"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,0" Height="36" Margin="0,0,10,0" Width="300">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconPhosphorIcons Kind="MagnifyingGlass" Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" Width="260"
                                 VerticalContentAlignment="Center" FontSize="13" Margin="6,0,0,0"
                                 Foreground="#1F2937">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </Border>
                <Button Command="{Binding AgregarCommand}" Cursor="Hand">
                    <Button.Template><ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#3B82F6" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="Plus" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Agregar" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#2563EB"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate></Button.Template>
                </Button>
                <Button Command="{Binding ExportarExcelCommand}" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Template><ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#16A34A" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Excel" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#15803D"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate></Button.Template>
                </Button>
                <Button Command="{Binding ExportarPdfCommand}" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Template><ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#DC2626" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="PDF" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#B91C1C"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate></Button.Template>
                </Button>
                
</StackPanel>
        </Grid>
        <Border Grid.Row="2" CornerRadius="12" Background="White" ClipToBounds="True">
            <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#000"/></Border.Effect>
            <DataGrid ItemsSource="{Binding ItemsView}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      GridLinesVisibility="None" HeadersVisibility="Column" BorderThickness="0"
                      SelectionMode="Single" RowStyle="{StaticResource DgRowStyle}" CellStyle="{StaticResource DgCellStyle}" ColumnHeaderStyle="{StaticResource DgHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="REPRESENTANTE" Binding="{Binding Representante}" Width="*"/>
                    <DataGridTextColumn Header="UBICACIÓN" Binding="{Binding Ubicacion}" Width="160"/>
                    <DataGridTextColumn Header="CLAVE SURE" Binding="{Binding ClaveSure}" Width="110"/>
                    <DataGridTextColumn Header="MATRÍCULA" Binding="{Binding Matricula}" Width="110"/>
                    <DataGridTextColumn Header="CAM" Binding="{Binding Cam}" Width="90"/>
                    <DataGridTextColumn Header="OBJETO" Binding="{Binding Objeto}" Width="130"/>
                    <DataGridTextColumn Header="PRECIO" Binding="{Binding Precio, StringFormat='{}{0:N2}'}" Width="100"/>
                    <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy}'}" Width="100"/>
                    <DataGridTemplateColumn Header="EXPEDIENTE" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="12,4" HorizontalAlignment="Left">
                                    <TextBlock x:Name="txt" Text="No Entregado" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#DC2626" VerticalAlignment="Center"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding ExpedienteEntregado}" Value="True">
                                        <Setter TargetName="txt" Property="Text" Value="Entregado"/>
                                        <Setter TargetName="txt" Property="Foreground" Value="#16A34A"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="ACCIONES" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button ToolTip="Modificar" Command="{Binding DataContext.ModificarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Cursor="Hand" Width="32" Height="32" Margin="2,0"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="#EFF6FF" CornerRadius="7"><iconPacks:PackIconPhosphorIcons Kind="PencilSimple" Width="15" Height="15" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#DBEAFE"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button ToolTip="Eliminar" Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Cursor="Hand" Width="32" Height="32" Margin="2,0"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="#FEF2F2" CornerRadius="7"><iconPacks:PackIconPhosphorIcons Kind="Trash" Width="15" Height="15" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#FEE2E2"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button ToolTip="Ver Cobros" Command="{Binding DataContext.VerCobrosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Cursor="Hand" Width="32" Height="32" Margin="2,0"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="#F0FDF4" CornerRadius="7"><iconPacks:PackIconPhosphorIcons Kind="CurrencyDollar" Width="15" Height="15" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#DCFCE7"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button ToolTip="Ver Gastos" Command="{Binding DataContext.VerGastosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Cursor="Hand" Width="32" Height="32" Margin="2,0"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="#FFF7ED" CornerRadius="7"><iconPacks:PackIconPhosphorIcons Kind="Receipt" Width="15" Height="15" Foreground="#EA580C" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#FFEDD5"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button ToolTip="Expediente" Command="{Binding DataContext.VerMovimientosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Cursor="Hand" Width="32" Height="32" Margin="2,0"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="bg" Background="#F5F3FF" CornerRadius="7"><iconPacks:PackIconPhosphorIcons Kind="ArrowsLeftRight" Width="15" Height="15" Foreground="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#EDE9FE"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <!-- Botón desplegable de Reportes -->
                                    <Button Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Click="BtnReportes_Click"
                                            Cursor="Hand" Margin="6,0,0,0">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="CurrencyCircleDollar" Width="14" Height="14" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Reporte Financiero" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding ReporteFinancieroPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="PDF" Foreground="#0F172A" FontSize="12" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding ReporteFinancieroExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Excel" Foreground="#0F172A" FontSize="12" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                                <MenuItem Command="{Binding BoletaPdfCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="IdentificationCard" Width="14" Height="14" Foreground="#0369A1" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Boleta / Expediente" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                                <Separator/>
                                                <!-- Movimientos por remedida -->
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="ArrowsLeftRight" Width="14" Height="14" Foreground="#EA580C" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Movimientos" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding MovimientosPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar PDF" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding MovimientosExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar Excel" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="#EDE9FE" CornerRadius="6" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="ChartBar" Width="13" Height="13" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Reportes" Foreground="#7C3AED" FontSize="12" FontWeight="SemiBold" Margin="5,0,4,0" VerticalAlignment="Center"/>
                                                        <iconPacks:PackIconPhosphorIcons Kind="CaretDown" Width="10" Height="10" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#DDD6FE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

