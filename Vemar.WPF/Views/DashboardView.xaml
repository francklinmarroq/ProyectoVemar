<UserControl
    x:Class="DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    Background="#F1F5F9"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="36,28,36,40">

            <!-- ── HEADER ──────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Panel de Control" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Background="#EFF6FF" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                            <TextBlock Text="{Binding FechaHoy}" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14,10" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconPhosphorIcons Kind="Buildings" Width="18" Height="18" Foreground="#1E40AF" VerticalAlignment="Center"/>
                        <TextBlock Text="Constructora Vemar" FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── SECCIÓN: KPI CARDS ──────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="4" Height="16" CornerRadius="2" Background="#3B82F6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="RESUMEN GENERAL" FontSize="11" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Clientes ── azul -->
                <Border Grid.Column="0" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left" Background="#3B82F6" CornerRadius="3,0,0,3"/>
                        <StackPanel Margin="18,16,16,16">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#EFF6FF" HorizontalAlignment="Left">
                                <iconPacks:PackIconPhosphorIcons Kind="Users" Width="18" Height="18" Foreground="#3B82F6"/>
                            </Border>
                            <TextBlock Text="{Binding TotalClientes}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Margin="0,10,0,0"/>
                            <TextBlock Text="Clientes" FontSize="12" FontWeight="SemiBold" Foreground="#3B82F6" Margin="0,3,0,0"/>
                            <TextBlock Text="registrados" FontSize="11" Foreground="#94A3B8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Remedidas ── morado -->
                <Border Grid.Column="2" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left" Background="#8B5CF6" CornerRadius="3,0,0,3"/>
                        <StackPanel Margin="18,16,16,16">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#F5F3FF" HorizontalAlignment="Left">
                                <iconPacks:PackIconPhosphorIcons Kind="Ruler" Width="18" Height="18" Foreground="#8B5CF6"/>
                            </Border>
                            <TextBlock Text="{Binding TotalRemedidas}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Margin="0,10,0,0"/>
                            <TextBlock Text="Remedidas" FontSize="12" FontWeight="SemiBold" Foreground="#8B5CF6" Margin="0,3,0,0"/>
                            <TextBlock FontSize="11" Foreground="#94A3B8" Margin="0,1,0,0">
                                <Run Text="{Binding RemedidasEntregadas}"/>
                                <Run Text=" expedientes entregados"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Proyectos ── verde -->
                <Border Grid.Column="4" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left" Background="#10B981" CornerRadius="3,0,0,3"/>
                        <StackPanel Margin="18,16,16,16">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#ECFDF5" HorizontalAlignment="Left">
                                <iconPacks:PackIconPhosphorIcons Kind="Buildings" Width="18" Height="18" Foreground="#10B981"/>
                            </Border>
                            <TextBlock Text="{Binding TotalProyectos}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Margin="0,10,0,0"/>
                            <TextBlock Text="Proyectos" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" Margin="0,3,0,0"/>
                            <TextBlock Text="activos" FontSize="11" Foreground="#94A3B8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Trámites ── ámbar -->
                <Border Grid.Column="6" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left" Background="#F59E0B" CornerRadius="3,0,0,3"/>
                        <StackPanel Margin="18,16,16,16">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#FFFBEB" HorizontalAlignment="Left">
                                <iconPacks:PackIconPhosphorIcons Kind="FolderOpen" Width="18" Height="18" Foreground="#F59E0B"/>
                            </Border>
                            <TextBlock Text="{Binding TotalTramites}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Margin="0,10,0,0"/>
                            <TextBlock Text="Trámites" FontSize="12" FontWeight="SemiBold" Foreground="#F59E0B" Margin="0,3,0,0"/>
                            <TextBlock Text="en gestión" FontSize="11" Foreground="#94A3B8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Contratos ── rosa -->
                <Border Grid.Column="8" CornerRadius="12" Background="White" ClipToBounds="True">
                    <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <Grid>
                        <Border Width="4" HorizontalAlignment="Left" Background="#EF4444" CornerRadius="3,0,0,3"/>
                        <StackPanel Margin="18,16,16,16">
                            <Border Width="36" Height="36" CornerRadius="9" Background="#FEF2F2" HorizontalAlignment="Left">
                                <iconPacks:PackIconPhosphorIcons Kind="FileText" Width="18" Height="18" Foreground="#EF4444"/>
                            </Border>
                            <TextBlock Text="{Binding TotalContratos}" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Margin="0,10,0,0"/>
                            <TextBlock Text="Contratos" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,3,0,0"/>
                            <TextBlock Text="firmados" FontSize="11" Foreground="#94A3B8" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── SECCIÓN CENTRAL: Expedientes + Trámites por estado ── -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Panel izquierdo: Expedientes de Remedidas -->
                <Border Grid.Column="0" CornerRadius="14" Background="White">
                    <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <StackPanel Margin="24,20">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#F5F3FF">
                                <iconPacks:PackIconPhosphorIcons Kind="ClipboardText" Width="16" Height="16" Foreground="#8B5CF6"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="EXPEDIENTES DE REMEDIDAS" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Estado de entrega" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Barra de progreso visual -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding BarraEntregadas}"/>
                                <ColumnDefinition Width="{Binding BarraPendientes}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="14" CornerRadius="7,0,0,7" Background="#8B5CF6"/>
                            <Border Grid.Column="1" Height="14" CornerRadius="0,7,7,0" Background="#E2E8F0"/>
                        </Grid>

                        <!-- Porcentaje grande -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{Binding PorcentajeEntregadas}" FontSize="36" FontWeight="Bold" Foreground="#8B5CF6"/>
                            <TextBlock Text=" entregados" FontSize="14" Foreground="#64748B" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                        </StackPanel>

                        <!-- Leyenda -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#F5F3FF" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Width="10" Height="10" CornerRadius="5" Background="#8B5CF6" VerticalAlignment="Center"/>
                                        <TextBlock Text=" Entregados" FontSize="11" Foreground="#6D28D9" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RemedidasEntregadas}" FontSize="22" FontWeight="Bold" Foreground="#5B21B6"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="10" Padding="12,10" Margin="6,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Width="10" Height="10" CornerRadius="5" Background="#CBD5E1" VerticalAlignment="Center"/>
                                        <TextBlock Text=" Pendientes" FontSize="11" Foreground="#475569" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RemedidasPendientes}" FontSize="22" FontWeight="Bold" Foreground="#334155"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Panel derecho: Trámites por Estado -->
                <Border Grid.Column="2" CornerRadius="14" Background="White">
                    <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                    <StackPanel Margin="24,20">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#FFFBEB">
                                <iconPacks:PackIconPhosphorIcons Kind="ChartBar" Width="16" Height="16" Foreground="#F59E0B"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="TRÁMITES POR ESTADO" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Distribución actual" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Sin datos placeholder -->
                        <TextBlock Text="Sin trámites registrados" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TramitesPorEstado.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Barras -->
                        <ItemsControl ItemsSource="{Binding TramitesPorEstado}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#374151"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Border Height="10" CornerRadius="5" Width="{Binding BarraPixels}"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding BarBrush}"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="{Binding BgBrush}" CornerRadius="6"
                                                Padding="4,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Count}" FontSize="11" FontWeight="Bold"
                                                       Foreground="{Binding TextBrush}" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── SECCIÓN: Actividad Reciente ─────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="4" Height="16" CornerRadius="2" Background="#06B6D4" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="ACTIVIDAD RECIENTE" FontSize="11" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
            </StackPanel>

            <Border CornerRadius="14" Background="White" Margin="0,0,0,4">
                <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.07" Color="#000"/></Border.Effect>
                <StackPanel Margin="24,20">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="32" Height="32" CornerRadius="8" Background="#ECFEFF">
                            <iconPacks:PackIconPhosphorIcons Kind="ClockCounterClockwise" Width="16" Height="16" Foreground="#06B6D4"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ÚLTIMOS REGISTROS" FontSize="11" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="Remedidas y trámites más recientes" FontSize="11" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Sin datos placeholder -->
                    <TextBlock Text="Sin actividad reciente" FontSize="12" Foreground="#94A3B8"
                               HorizontalAlignment="Center" Margin="0,20"
                               Visibility="{Binding SinActividad, Converter={StaticResource BoolToVis}}"/>

                    <!-- Lista de actividad -->
                    <ItemsControl ItemsSource="{Binding ActividadReciente}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8"
                                                Background="{Binding IconBgBrush}" VerticalAlignment="Center">
                                            <iconPacks:PackIconPhosphorIcons Kind="{Binding Icono}" Width="16" Height="16"
                                                                             Foreground="{Binding IconBrush}"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Titulo}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitulo}" FontSize="11" Foreground="#64748B"
                                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" Background="#EFF6FF" CornerRadius="6" Padding="8,4"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FechaTexto}" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#2563EB"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
