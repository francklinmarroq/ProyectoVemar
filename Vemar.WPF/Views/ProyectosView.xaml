<UserControl x:Class="ProyectosView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Background="#F1F5F9">
    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock"><Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#3B82F6"/><Setter Property="Margin" Value="0,0,0,4"/></Style>
        <Style x:Key="Fld" TargetType="TextBox"><Setter Property="Height" Value="36"/><Setter Property="Padding" Value="10,0"/><Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="BorderThickness" Value="1"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
        <Style x:Key="Cmb" TargetType="ComboBox"><Setter Property="Height" Value="36"/><Setter Property="Padding" Value="8,0"/><Setter Property="BorderBrush" Value="#E2E8F0"/><Setter Property="BorderThickness" Value="1"/></Style>
        <!-- DataGrid Styles -->
        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#F0F4F8" BorderThickness="0,0,0,1">
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </SelectiveScrollingGrid.ColumnDefinitions>
                                <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" Grid.Column="1"/>
                            </SelectiveScrollingGrid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F9FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="10" Background="#EFF6FF" VerticalAlignment="Center">
                    <iconPacks:PackIconPhosphorIcons Kind="Buildings" Width="20" Height="20" Foreground="#3B82F6"/>
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Proyectos" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding ItemsView.Count, StringFormat='Total: {0} registros'}" FontSize="12" Foreground="#3B82F6"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10,0" Height="36" Margin="0,0,10,0" Width="300">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconPhosphorIcons Kind="MagnifyingGlass" Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" Width="260"
                                 VerticalContentAlignment="Center" FontSize="13" Margin="6,0,0,0" Foreground="#1F2937">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </Border>
                <Button Command="{Binding AgregarCommand}" Cursor="Hand">
                    <Button.Template><ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#3B82F6" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="Plus" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Agregar" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#2563EB"/></Trigger></ControlTemplate.Triggers>
                    </ControlTemplate></Button.Template>
                </Button>
                <Button Command="{Binding ExportarExcelCommand}" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Template><ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#16A34A" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Excel" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#15803D"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate></Button.Template>
                </Button>
                <Button Command="{Binding ExportarPdfCommand}" Cursor="Hand" Margin="8,0,0,0">
                    <Button.Template><ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="#DC2626" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="14" Height="14" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="PDF" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#B91C1C"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate></Button.Template>
                </Button>
                
            </StackPanel>
        </Grid>
        <Border Grid.Row="2" CornerRadius="12" Background="White" ClipToBounds="True">
            <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#000"/></Border.Effect>
            <DataGrid ItemsSource="{Binding ItemsView}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      GridLinesVisibility="None" HeadersVisibility="Column" BorderThickness="0"
                        SelectionMode="Single" RowStyle="{StaticResource DgRowStyle}" CellStyle="{StaticResource DgCellStyle}" ColumnHeaderStyle="{StaticResource DgHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="CLIENTE" Binding="{Binding Cliente.Nombre}" Width="160"/>
                    <DataGridTextColumn Header="CLAVE SURE" Binding="{Binding ClaveSure}" Width="110"/>
                    <DataGridTextColumn Header="MATRÍCULA" Binding="{Binding Matricula}" Width="110"/>
                    <DataGridTextColumn Header="UBICACIÓN" Binding="{Binding Ubicacion}" Width="140"/>
                    <DataGridTextColumn Header="ÁREA" Binding="{Binding Area, StringFormat='{}{0:N2}'}" Width="90"/>
                    <DataGridTemplateColumn Header="ACCIONES" Width="550">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Command="{Binding DataContext.ModificarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="#EFF6FF" CornerRadius="6" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="PencilSimple" Width="13" Height="13" Foreground="#3B82F6" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Modificar" Foreground="#3B82F6" FontSize="12" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#DBEAFE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Command="{Binding DataContext.VerGastosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="#FFF7ED" CornerRadius="6" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="Receipt" Width="13" Height="13" Foreground="#EA580C" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Gastos" Foreground="#EA580C" FontSize="12" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#FFEDD5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Command="{Binding DataContext.VerContratosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="#ECFDF5" CornerRadius="6" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="FileText" Width="13" Height="13" Foreground="#10B981" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Contratos" Foreground="#10B981" FontSize="12" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#D1FAE5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="#FEE2E2" CornerRadius="6" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="Trash" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Eliminar" Foreground="#DC2626" FontSize="12" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#FECACA"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Botón Reportes con menú desplegable -->
                                    <Button Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Click="BtnReportes_Click"
                                            Cursor="Hand">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="CurrencyCircleDollar" Width="14" Height="14" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Reporte Financiero" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding ReporteFinancieroPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar PDF" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding ReporteFinancieroExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar Excel" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                                <MenuItem Command="{Binding BoletaPdfCommand}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="IdentificationCard" Width="14" Height="14" Foreground="#0369A1" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Boleta / Expediente" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                                <Separator/>
                                                <!-- Trámites -->
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="ClipboardText" Width="14" Height="14" Foreground="#0369A1" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Trámites del Proyecto" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding TramitesPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar PDF" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding TramitesExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar Excel" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                                <!-- Asignaciones -->
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="UserList" Width="14" Height="14" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Asignaciones del Proyecto" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding AsignacionesPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar PDF" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding AsignacionesExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar Excel" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                                <!-- Avances -->
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="TrendUp" Width="14" Height="14" Foreground="#EA580C" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Avances del Proyecto" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding AvancesPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar PDF" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding AvancesExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar Excel" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                                <!-- Contratos -->
                                                <MenuItem>
                                                    <MenuItem.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <iconPacks:PackIconPhosphorIcons Kind="FileText" Width="14" Height="14" Foreground="#10B981" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Contratos del Proyecto" FontSize="12" FontWeight="SemiBold" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </MenuItem.Header>
                                                    <MenuItem Command="{Binding ContratosPdfCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FilePdf" Width="13" Height="13" Foreground="#DC2626" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar PDF" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                    <MenuItem Command="{Binding ContratosExcelCommand}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Header>
                                                            <StackPanel Orientation="Horizontal">
                                                                <iconPacks:PackIconPhosphorIcons Kind="FileXls" Width="13" Height="13" Foreground="#16A34A" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Exportar Excel" FontSize="12" Foreground="#1F2937" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </MenuItem.Header>
                                                    </MenuItem>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" Background="#F3E8FF" CornerRadius="6" Padding="10,5">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconPhosphorIcons Kind="ChartBar" Width="13" Height="13" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Reportes" Foreground="#7C3AED" FontSize="12" FontWeight="SemiBold" Margin="5,0,4,0" VerticalAlignment="Center"/>
                                                        <iconPacks:PackIconPhosphorIcons Kind="CaretDown" Width="10" Height="10" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#EDE9FE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>


